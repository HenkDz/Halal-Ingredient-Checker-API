# ============================================================
# Halal Check API - Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# --- Application ---
# Host and port for the API server
HOST=0.0.0.0
PORT=8000

# Gunicorn worker count (default: 4, recommended: 2-4 per CPU core)
WORKERS=4

# Log level: debug, info, warning, error, critical
LOG_LEVEL=info

# Local port mapping (used by docker-compose, not the app itself)
APP_PORT=8000

# --- Polar.sh Payment Integration ---
# Required for Pro tier subscription payments
# Leave empty to disable Polar (manual tier assignment still works)
POLAR_ACCESS_TOKEN=
POLAR_WEBHOOK_SECRET=
POLAR_PRO_MONTHLY_PRODUCT_ID=
POLAR_PRO_YEARLY_PRODUCT_ID=

# Polar environment: "production" or "sandbox"
POLAR_SERVER_ENV=production

# URLs for checkout redirect (defaults to example.com)
POLAR_SUCCESS_URL=https://halalcheck.example.com/success
POLAR_CANCEL_URL=https://halalcheck.example.com/cancel

# --- Production (Optional) ---
# Set these for production deployments behind a reverse proxy
# CORS_ORIGINS=https://halalcheck.example.com
# API_RATE_LIMIT_FREE=30
# API_RATE_LIMIT_PRO=300
# API_RATE_LIMIT_ENTERPRISE=3000
